# ============================================================================
# Kàff GUI API — exemple de configuration (.env)
# ----------------------------------------------------------------------------
# Copier vers `.env` et adapter. NE JAMAIS committer le .env réel.
# ============================================================================

# ----- Django core ---------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=change-me-in-prod-use-a-50-chars-random-string-please
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Dakar
DJANGO_LANGUAGE_CODE=fr

# ----- Database (PostgreSQL 15) --------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DB_NAME
DATABASE_URL=postgres://kaff_dev:kaff_dev_2026@localhost:5432/kaff_gui_dev
DATABASE_CONN_MAX_AGE=60
DATABASE_SSL_REQUIRE=False

# ----- CORS (mobile app + dev) ---------------------------------------------
# Liste séparée par des virgules
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://127.0.0.1:19000

# ----- JWT (simplejwt) -----------------------------------------------------
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
JWT_ROTATE_REFRESH_TOKENS=True
JWT_BLACKLIST_AFTER_ROTATION=True

# ----- Rate limiting / Brute-force (django-axes) ---------------------------
AXES_FAILURE_LIMIT=5
AXES_COOLOFF_TIME_MINUTES=5
AXES_LOCKOUT_PARAMETERS=ip_address,username

# ----- Chiffrement applicatif des credentials (X25519 sealed box) ----------
# Générer en local avec:
#   uv run python manage.py shell -c "from apps.users.services.keypair import generate_pair; generate_pair()"
# En prod (Railway/Render), DOIT être défini explicitement. En dev, laissé vide
# = keypair généré au boot (rotation à chaque restart, mobile re-fetch via 410).
APP_CRYPTO_PRIVATE_KEY=
APP_CRYPTO_PUBLIC_KEY=

# ----- Logging -------------------------------------------------------------
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_FORMAT=json

# ----- Sécurité (production uniquement) ------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
