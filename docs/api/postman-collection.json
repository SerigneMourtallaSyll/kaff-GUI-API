                "api",
                "v1",
                "auth",
                "register",
                "confirm"
              ]
            },
            "description": "Confirme l'enrôlement 2FA en validant le 1er code généré par l'Authenticator. Émet les tokens JWT — l'utilisateur est désormais authentifié.",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"$ref\": \"#/components/schemas/TOTPVerifyRequest\"\n}"
            }
          }
        }
      ]
    },
